{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowSnowflakeListProjectDataBucket",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": "arn:aws:s3:::<PROJECT_DATA_BUCKET>"
    },
    {
      "Sid": "AllowSnowflakeReadProjectDataObjects",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:GetObjectVersion"
      ],
      "Resource": "arn:aws:s3:::<PROJECT_DATA_BUCKET>/*"
    }
  ]
}
